<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Details</title>
    </head>

    <body class="bg-[#101010]">
        <%- include("partials/navbar.ejs") %>
        
        <main class="max-w-[1440px] mx-auto px-4 lg:px-20 mt-8 lg:mt-12">
            
            <header>
                <div class="flex justify-between items-center">
                    <a class="flex items-center text-[#898A8B] hover:text-white transition-colors no-underline font-medium" href="/">
                        <img src="/assets/images/icon-chevron-left.svg" alt="" aria-hidden="true" class="w-4 h-4">
                        <span class="ms-2">Back</span>
                    </a>
                    
                    <div class="flex gap-x-4">
                        <a href="/edit-goal" class="text-[#B7B7B7] hover:text-white font-medium transition-colors no-underline">Edit goal</a>
                        
                        <button type="button" class="text-[#EF4444] hover:text-red-300 font-medium transition-colors bg-transparent border-none p-0 cursor-pointer">Delete goal</button>
                    </div>
                </div>

                <div class="mt-4 lg:mt-6">
                    <h1 class="font-bricolage text-[36px] lg:text-[44px] font-semibold my-0 text-white">MacBook Pro M4</h1>
                    <p class="text-[#B7B7B7] font-medium text-[14px] mt-2">
                        Due <time datetime="2026-06-01">1 Jun 2026</time> <span aria-hidden="true">•</span> Created <time datetime="2025-11-15">Nov 15, 2025</time>
                    </p>
                </div>
            </header>

            <div class="mt-8 lg:mt-10 grid grid-cols-1 lg:grid-cols-3 gap-y-8 lg:gap-x-12 items-start mb-12">
                
                <div class="lg:col-span-2 flex flex-col gap-6">
                    
                    <section aria-label="Goal Progress" class="bg-[#1F1F1F] text-white border border-[#898A8B]/20 rounded-2xl p-6 flex flex-col justify-between">
                        <div class="flex justify-between items-center mb-8">
                            <p class="text-[44px] text-[#FF5722] font-bold">76%</p>
                            <p class="text-[16px] font-semibold text-[#B7B7B7]">$599.00 remaining</p>
                        </div>

                        <div>
                            <div class="w-full bg-[#313131] h-3 rounded-full overflow-hidden" aria-hidden="true">
                                <div class="h-full bg-[#FF5722] w-[76%] rounded-full relative overflow-hidden">
                                    <div class="absolute inset-0 bg-[repeating-linear-gradient(120deg,rgba(0,0,0,0.18)_0px,rgba(0,0,0,0.18)_1px,transparent_1px,transparent_6px)]"></div>
                                </div>
                            </div>

                            <div class="mt-4">
                                <div class="flex items-center justify-between text-[14px] font-medium">
                                    <span>$1,900.00</span>
                                    <span>of $2,499.00</span>
                                </div>
                                <div class="flex items-center justify-between text-[14px] font-medium text-[#B7B7B7]">
                                    <span>Saved so far</span>
                                    <span>Target</span>
                                </div>
                            </div>
                        </div>    
                    </section>


                    <section aria-labelledby="form-heading" class="bg-[#1F1F1F] text-white border border-[#898A8B]/20 rounded-2xl p-6 flex flex-col justify-between">
                        <h2 id="form-heading" class="font-semibold text-[20px] mb-4">Add deposit</h2>

                        <form action="/your-submit-url" method="POST" class="w-full flex flex-col gap-5 text-white">
                            <div class="flex flex-col gap-2">
                                <label for="amount" class="text-[16px] font-medium tracking-wide pl-1 text-white">Amount</label>
                                <div class="relative flex items-center">
                                    <span class="absolute left-4 text-white text-[18px] font-medium" aria-hidden="true">$</span>
                                    <input 
                                        type="number" 
                                        id="amount" 
                                        name="amount" 
                                        placeholder="0.00" 
                                        class="w-full bg-[#313131] border border-[#B7B7B7]/30 rounded-xl py-4 pl-9 pr-4 text-white placeholder-white/30 text-[18px] focus:outline-none focus:border-[#FF5722] transition-colors"
                                    >
                                </div>
                            </div>

                            <div class="flex flex-col gap-2">
                                <label for="note" class="text-[16px] font-medium tracking-wide pl-1 text-white">Note (optional)</label>
                                <input 
                                    type="text" 
                                    id="note" 
                                    name="note" 
                                    placeholder="e.g. Monthly savings" 
                                    class="w-full bg-[#1F1F1F] border border-[#898A8B]/30 rounded-xl p-4 text-white placeholder-[#B7B7B7] font-medium text-[16px] focus:outline-none focus:border-[#FF5722] transition-colors"
                                >
                            </div>

                            <button 
                                type="submit" 
                                class="w-full bg-[#FF5722] text-black font-semibold text-[16px] py-4 rounded-full hover:bg-[#e04c1d] active:scale-[0.99] transition-all mt-2 cursor-pointer focus:outline-none"
                            >
                                Add funds
                            </button>
                        </form>
                    </section>
                </div>


                <section aria-labelledby="history-heading" class="text-white px-1 lg:mt-0 min-w-0 w-full">
                    <div class="flex justify-between items-baseline mb-4 whitespace-nowrap">
                        <h2 id="history-heading" class="font-semibold text-[22px] tracking-tight">Deposit history</h2>
                        <span class="text-[14px] text-[#B7B7B7] font-medium">7 deposits</span>
                    </div>

                    <ul class="flex flex-col m-0 p-0 list-none border-t border-[#313131]/60">
                        
                        <li class="flex items-center justify-between py-4 border-b border-[#313131]/60 gap-x-4">
                            <div class="flex items-center gap-x-4 min-w-0">
                                <div class="w-10 h-10 rounded-full bg-[#1F1F1F] border border-[#898A8B]/10 flex items-center justify-center text-[#B7B7B7] shrink-0" aria-hidden="true">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"></path>
                                    </svg>
                                </div>
                                <div class="min-w-0">
                                    <p class="text-[14px] font-semibold text-white m-0 truncate whitespace-nowrap">Monthly savings</p>
                                    <p class="text-[14px] text-[#B7B7B7] font-medium m-0 mt-0.5 whitespace-nowrap"><time datetime="2026-01-01">Jan 1, 2026</time></p>
                                </div>
                            </div>
                            <span class="text-[16px] font-bold text-[#22C55E] tracking-wide shrink-0 whitespace-nowrap">+$200.00</span>
                        </li>

                        <li class="flex items-center justify-between py-4 border-b border-[#313131]/60 gap-x-4">
                            <div class="flex items-center gap-x-4 min-w-0">
                                <div class="w-10 h-10 rounded-full bg-[#1F1F1F] border border-[#898A8B]/10 flex items-center justify-center text-[#B7B7B7] shrink-0" aria-hidden="true">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"></path>
                                    </svg>
                                </div>
                                <div class="min-w-0">
                                    <p class="text-[14px] font-semibold text-white m-0 truncate whitespace-nowrap">Bonus from client work</p>
                                    <p class="text-[14px] text-[#B7B7B7] font-medium m-0 mt-0.5 whitespace-nowrap"><time datetime="2026-02-20">Feb 20, 2026</time></p>
                                </div>
                            </div>
                            <span class="text-[16px] font-bold text-[#22C55E] tracking-wide shrink-0 whitespace-nowrap">+$250.00</span>
                        </li>

                        <li class="flex items-center justify-between py-4 border-b border-[#313131]/60 gap-x-4">
                            <div class="flex items-center gap-x-4 min-w-0">
                                <div class="w-10 h-10 rounded-full bg-[#1F1F1F] border border-[#898A8B]/10 flex items-center justify-center text-[#B7B7B7] shrink-0" aria-hidden="true">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"></path>
                                    </svg>
                                </div>
                                <div class="min-w-0">
                                    <p class="text-[14px] font-semibold text-white m-0 truncate whitespace-nowrap">Monthly savings</p>
                                    <p class="text-[14px] text-[#B7B7B7] font-medium m-0 mt-0.5 whitespace-nowrap"><time datetime="2026-02-01">Feb 1, 2026</time></p>
                                </div>
                            </div>
                            <span class="text-[16px] font-bold text-[#22C55E] tracking-wide shrink-0 whitespace-nowrap">+$200.00</span>
                        </li>

                        <li class="flex items-center justify-between py-4 border-b border-[#313131]/60 gap-x-4">
                            <div class="flex items-center gap-x-4 min-w-0">
                                <div class="w-10 h-10 rounded-full bg-[#1F1F1F] border border-[#898A8B]/10 flex items-center justify-center text-[#B7B7B7] shrink-0" aria-hidden="true">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"></path>
                                    </svg>
                                </div>
                                <div class="min-w-0">
                                    <p class="text-[14px] font-semibold text-white m-0 truncate whitespace-nowrap">Sold old monitor</p>
                                    <p class="text-[14px] text-[#B7B7B7] font-medium m-0 mt-0.5 whitespace-nowrap"><time datetime="2025-12-18">Dec 18, 2025</time></p>
                                </div>
                            </div>
                            <span class="text-[16px] font-bold text-[#22C55E] tracking-wide shrink-0 whitespace-nowrap">+$350.00</span>
                        </li>

                        <li class="flex items-center justify-between py-4 border-b border-[#313131]/60 gap-x-4">
                            <div class="flex items-center gap-x-4 min-w-0">
                                <div class="w-10 h-10 rounded-full bg-[#1F1F1F] border border-[#898A8B]/10 flex items-center justify-center text-[#B7B7B7] shrink-0" aria-hidden="true">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"></path>
                                    </svg>
                                </div>
                                <div class="min-w-0">
                                    <p class="text-[14px] font-semibold text-white m-0 truncate whitespace-nowrap">Monthly savings</p>
                                    <p class="text-[14px] text-[#B7B7B7] font-medium m-0 mt-0.5 whitespace-nowrap"><time datetime="2025-12-01">Dec 1, 2025</time></p>
                                </div>
                            </div>
                            <span class="text-[16px] font-bold text-[#22C55E] tracking-wide shrink-0 whitespace-nowrap">+$200.00</span>
                        </li>

                        <li class="flex items-center justify-between py-4 border-b border-[#313131]/60 gap-x-4">
                            <div class="flex items-center gap-x-4 min-w-0">
                                <div class="w-10 h-10 rounded-full bg-[#1F1F1F] border border-[#898A8B]/10 flex items-center justify-center text-[#B7B7B7] shrink-0" aria-hidden="true">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"></path>
                                    </svg>
                                </div>
                                <div class="min-w-0">
                                    <p class="text-[14px] font-semibold text-white m-0 truncate whitespace-nowrap">Starting fund from freelance project</p>
                                    <p class="text-[14px] text-[#B7B7B7] font-medium m-0 mt-0.5 whitespace-nowrap"><time datetime="2025-11-15">Nov 15, 2025</time></p>
                                </div>
                            </div>
                            <span class="text-[16px] font-bold text-[#22C55E] tracking-wide shrink-0 whitespace-nowrap">+$500.00</span>
                        </li>
                    </ul>
                </section>

            </div>
        </main>
    </body>
</html>